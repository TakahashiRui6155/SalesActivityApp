<?xml version="1.0" encoding="UTF-8"?>
<tomcatProjectProperties>
    <rootDir>/</rootDir>
    <workDir>work</workDir>
    <exportSource>false</exportSource>
    <reloadable>true</reloadable>
    <redirectLogger>false</redirectLogger>
    <updateXml>true</updateXml>
    <warLocation></warLocation>
    <extraInfo></extraInfo>
    <mavenClasspath>true</mavenClasspath>
    <webPath>/SalesActivityApp</webPath>
    <webClassPathEntries>
        <webClassPathEntry>/SalesActivityApp/WEB-INF/classes</webClassPathEntry>
        <webClassPathEntry>/SalesActivityApp/work</webClassPathEntry>
    </webClassPathEntries>
</tomcatProjectProperties>
